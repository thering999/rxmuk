# rxmuk Docker Configuration
# Copy this file to .env and update values as needed

# Database
DB_HOST=rxmuk_db
DB_NAME=rxmuk_db
DB_USER=rxmuk_user
DB_PASSWORD=rxmuk_pass123
DB_PORT=3306

# MySQL Root (for initialization only)
MYSQL_ROOT_PASSWORD=rootpass123

# Application
APP_NAME=rxmuk
APP_ENV=development
APP_DEBUG=true

# Server
SERVER_HOST=localhost
HTTP_PORT=80
PHPMYADMIN_PORT=8080
